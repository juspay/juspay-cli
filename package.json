{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@juspay/cli",
  "version": "0.7.0",
  "description": "Juspay skills + MCP servers for AI coding agents (Claude Code, Codex, Gemini, OpenCode, Cursor, Windsurf, Copilot). One command, any agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juspay/juspay-cli.git"
  },
  "homepage": "https://github.com/juspay/juspay-cli#readme",
  "type": "module",
  "bin": {
    "juspay": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "bun run clean && bun run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": [
    "dist",
    "scripts",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@clack/prompts": "^0.10.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/which": "^3.0.4",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.0",
    "typescript": "^5.8.0",
    "which": "^5.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@juspay/cli": "file:juspay-cli-0.7.0.tgz"
  }
}
